<div tal:condition="python: view.is_visible()"
     i18n:domain="senaite.core">

  <div class="visualClear"></div>

  <div id="portal-alert"
       tal:define="sample python: view.sample;
                   retest python: view.get_retest();
                   info   python: view.get_invalidation_info();
                   reason info/comment|nothing;">

    <div class="portlet-alert-item alert alert-warning alert-dismissible">
      <button type="button" class="close" data-dismiss="alert"
              aria-label="Close" i18n:attributes="aria-label">
        <span aria-hidden="true">&times;</span>
      </button>
      <strong i18n:translate="">Warning</strong>

      <!-- With a reason -->
      <p class="title mb-0"
         tal:condition="python:reason"
         i18n:translate="">
        This sample was invalidated by
        <span i18n:name="actor_fullname" tal:replace="info/fullname"></span>
        (<span i18n:name="actor_id" tal:replace="info/actor"></span>) on
        <span i18n:name="date" tal:replace="info/date"></span> for the
        following reason(s):
        <span i18n:name="reason" tal:replace="reason"></span>.
      </p>

      <!-- Without a reason -->
      <p class="title mb-0"
         tal:condition="python:not reason"
         i18n:translate="">
        This sample was invalidated by
        <span i18n:name="actor_fullname" tal:replace="info/fullname"></span>
        (<span i18n:name="actor_id" tal:replace="info/actor"></span>) on
        <span i18n:name="date" tal:replace="info/date"></span>.
      </p>

      <!-- With a retest -->
      <p tal:condition="python:retest" i18n:translate="">
        Please follow the link to the retest
        <a i18n:name="retest_id"
           tal:attributes="href python:retest.absolute_url()"
           tal:content="python: retest.getId()"></a>.
      </p>

    </div>
  </div>
</div>
